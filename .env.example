# World-as-Oracle Environment Variables
# Copy this to .env and fill in your values

# Required: Your Anthropic API key (for LLM impact scoring in Layer 3)
ANTHROPIC_API_KEY=sk-ant-xxxx

# Optional: Database URL
# Default: SQLite at oracle.db (local file)
# Production: Use Railway Postgres add-on and set to:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=oracle.db

# Optional: Port (Railway/Render set this automatically)
PORT=8080
